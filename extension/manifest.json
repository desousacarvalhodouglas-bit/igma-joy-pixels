{
  "manifest_version": 3,
  "name": "Lovable Debug Tool",
  "version": "2.0.0",
  "description": "Envia instruções + imagens diretamente para o Debug Tool do Lovable, sem precisar abrir o app antes.",
  "permissions": ["storage", "tabs"],
  "host_permissions": [
    "https://*.lovable.app/*",
    "https://*.lovableproject.com/*",
    "https://bcafttsxvperfslgjphb.supabase.co/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  },
  "content_scripts": [
    {
      "matches": ["https://*.lovable.app/*", "https://*.lovableproject.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "48": "icon.png",
    "128": "icon.png"
  }
}
