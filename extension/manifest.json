{
  "manifest_version": 3,
  "name": "Lovable Debug Tool",
  "version": "3.2.0",
  "description": "Envia instruções + imagens diretamente para o Debug Tool do Lovable, com login automático Google ou email/senha.",
  "permissions": ["storage", "tabs", "identity"],
  "host_permissions": [
    "https://*.lovable.app/*",
    "https://*.lovableproject.com/*",
    "https://bcafttsxvperfslgjphb.supabase.co/*",
    "https://accounts.google.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  },
  "content_scripts": [
    {
      "matches": ["https://*.lovable.app/*", "https://*.lovableproject.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "48": "icon.png",
    "128": "icon.png"
  }
}
