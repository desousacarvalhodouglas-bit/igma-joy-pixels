{
  "manifest_version": 3,
  "name": "Lovable Debug Tool",
  "version": "4.1.0",
  "description": "Captura automaticamente o project_id e o Bearer token da Lovable e envia instruções de debug pelo popup.",
  "permissions": [
    "storage",
    "tabs",
    "webRequest",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://lovable.dev/*",
    "https://api.lovable.dev/*",
    "https://*.lovable.app/*",
    "https://*.lovableproject.com/*",
    "https://bcafttsxvperfslgjphb.supabase.co/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  },
  "content_scripts": [
    {
      "matches": ["https://lovable.dev/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "48": "icon.png",
    "128": "icon.png"
  }
}
